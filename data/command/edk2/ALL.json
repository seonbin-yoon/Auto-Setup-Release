{
    "ALL" : [
        {
            "cmd": ["mkdir", "src"],
            "cwd": "default",
            "explan": "홈 디렉터리에 'src' 폴더를 생성합니다.."
        },
        {
            "cmd": ["git", "clone", "https://github.com/tianocore/edk2"],
            "cwd": "src",
            "explan": "edk2를 git에서 받아옵니다.."
        },
        {
            "cmd": ["git", "submodule", "update", "--init"],
            "cwd": "src/edk2",
            "explan": "edk2의 의존성 패키지를 git으로 해결합니다.."
        },
        {
            "cmd": ["make", "-C", "BaseTools"],
            "cwd": "src/edk2",
            "explan": "빌드툴을 첫번째로 make 합니다.."
        },
        {
            "cmd" : ["bash", "-c", "source edksetup.sh"],
            "cwd": "src/edk2",
            "explan": "edksetup.sh를 실행합니다."
        },
        {
            "cmd": ["make", "-C", "BaseTools"],
            "cwd": "src/edk2",
            "explan": "빌드툴을 두번째로 make 합니다.."
        }
    ]
}
